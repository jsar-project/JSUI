:root {
  --theme-color: #3498db;
  --theme-bg: #e8f4f8;
  --theme-border: 2px solid #3498db;
  --theme-radius: 12px;
  --theme-padding: 20px;
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  color: #333333;
}

.container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.page-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
  text-align: center;
  color: #1a1a1a;
}

.card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #2c3e50;
}
