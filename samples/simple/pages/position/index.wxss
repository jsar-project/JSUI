.container {
  flex-direction: column;
  padding: 20px;
  background-color: #fff;
}

.section {
  flex-direction: column;
  margin-bottom: 30px;
}

.title {
  font-weight: bold;
  font-size: 20px;
  margin-bottom: 10px;
  color: black;
}

.relative-box {
  width: 200px;
  height: 100px;
  background-color: #e0e0e0;
  position: relative;
}

.relative-child {
  position: relative;
  top: 20px;
  left: 20px;
  width: 150px;
  height: 50px;
  background-color: #007aff;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
}

.relative-container {
  position: relative;
  width: 100%;
  height: 150px;
  background-color: #e0e0e0;
}

.absolute-child1 {
  position: absolute;
  top: 10px;
  left: 10px;
  width: 150px;
  height: 50px;
  background-color: #ff3b30;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
}

.absolute-child2 {
  position: absolute;
  bottom: 10px;
  right: 10px;
  width: 150px;
  height: 50px;
  background-color: #34c759;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
}

.absolute-inset {
  position: absolute;
  inset: 20px;
  background-color: #ff9500;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
}
