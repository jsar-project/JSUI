.flex-row {
  display: flex;
  flex-direction: row;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.align-center {
  align-items: center;
}
.item {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, #1989fa, #0570db);
  color: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 6px;
  border-radius: 8px;
  font-weight: 600;
  box-shadow: 0 2px 4px rgba(25, 137, 250, 0.2);
}
